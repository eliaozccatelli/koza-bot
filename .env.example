# 🔐 Esempio di configurazione - RINOMINA IN .env e inserisci i tuoi dati
# NOTA: Non committare mai il file .env su GitHub!

# 🔐 Google Gemini API Keys
# Ottieni da: https://aistudio.google.com/app/apikey
# Supporto MULTI-KEY: inserisci più key separate da virgola
# Esempio: GEMINI_API_KEY=key1,key2,key3
# Quando una key finisce la quota, passa automaticamente alla prossima
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Telegram Bot Token (ottieni da BotFather su Telegram)
TELEGRAM_TOKEN="YOUR_TELEGRAM_TOKEN_HERE"

# TheSportsDB API (gratuito - default "123", opzionale)
THESPORTSDB_API_KEY="123"

# RapidAPI Key (ottieni da https://rapidapi.com - piano gratuito)
# API: "Free API Live Football Data" di Creativesdev
RAPIDAPI_KEY="YOUR_RAPIDAPI_KEY_HERE"
RAPIDAPI_HOST="free-api-live-football-data.p.rapidapi.com"

# DEPRECATED - API-Football (non più usato, usiamo Gemini AI)
# API_KEY="YOUR_API_KEY_HERE"
